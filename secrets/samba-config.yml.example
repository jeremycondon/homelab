# Copy to secrets/samba-config.yml, fill in values, then run: make encrypt-secrets
# uid/gid 1000 is standard for the first non-root user on Ubuntu

auth:
  - user: yourname
    group: yourname
    uid: 1000
    gid: 1000
    password: changeme

global:
  - "force user = yourname"
  - "force group = yourname"

share:
  - name: files
    path: /files
    browsable: yes
    readonly: no
    guestok: no
    validusers: yourname
    writelist: yourname
    veto: no

  - name: timemachine
    path: /timemachine
    browsable: yes
    readonly: no
    guestok: no
    validusers: yourname
    writelist: yourname
    veto: no
    fruit:
      enabled: yes
      time machine: yes
      # Adjust to ~1.5x the size of your Mac's internal drive
      time machine max size: 500G
